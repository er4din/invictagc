# WordPress core
/wp-admin/
/wp-includes/
/wp-*.php
/index.php
/xmlrpc.php
/license.txt
/readme.html

# WordPress config (contains DB credentials)
wp-config.php
wp-config-sample.php

# Uploads (media files — large and environment-specific)
/wp-content/uploads/

# Cache and generated files
/wp-content/cache/
/wp-content/upgrade/
/wp-content/upgrade-temp-backup/
/wp-content/backup-db/
/wp-content/advanced-cache.php
/wp-content/wp-cache-config.php
/wp-content/litespeed/
/wp-content/fonts/
/wp-content/languages/

# Backups
/wp-content/ai1wm-backups/

# Nested/misplaced wp-content
/wp-content/wp-content/

# Log files in wp-content root
/wp-content/*.txt

# Logs
*.log
/wp-content/debug.log

# Maintenance mode trigger — must never be committed (would deploy to live and lock users out)
.maintenance

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
